# ── SENTINEL — Environment Configuration ────────────────────────────────────
# Copy to .env and edit as needed.
# All values below are the defaults from core/config.py.

# YOLOv8 model (yolov8n.pt | yolov8s.pt | yolov8m.pt)
YOLO_MODEL=yolov8n.pt

# Inference device: "cpu" or "cuda"
YOLO_DEVICE=cpu

# Anomaly reconstruction error threshold (lower = more sensitive)
ANOMALY_THRESHOLD=0.045

# Minimum speed to flag as running (normalised by frame diagonal)
SPEED_RUN_THRESHOLD=0.025

# Frames a person must stay in same zone to flag as loitering
LOITER_FRAMES=90

# API host/port
API_HOST=0.0.0.0
API_PORT=8000

# MJPEG stream max FPS cap
STREAM_FPS_CAP=25
